{
  "name": "dawn-of-man",
  "version": "0.1.0",
  "description": "Dawn of Man - Express, libSQL, and Drizzle backend for a 2D turn-based RPG project.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db": "drizzle-kit push && node src/db/seed.js",
    "db:reset": "node src/db/reset.js && npm run db",
    "db:seed": "node src/db/seed.js",
    "balance": "node scripts/balance-report.js"
  },
  "keywords": [
    "express",
    "libsql",
    "drizzle",
    "rpg",
    "backend"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@libsql/client": "^0.15.14",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "nodemon": "^3.1.9"
  }
}