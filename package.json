{
  "name": "realmforge-shards-of-the-worldheart",
  "version": "0.1.0",
  "description": "Realmforge: Shards of the Worldheart - Express, libSQL, and Drizzle backend for a third-person 3D action RPG project.",
  "type": "module",
  "main": "src/server.js",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:seed": "node src/db/seed.js",
    "client:dev": "npm run dev -w client",
    "lint": "npm run lint -w client",
    "test": "npm run test -w client",
    "build": "npm run build -w client"
  },
  "keywords": [
    "express",
    "libsql",
    "drizzle",
    "rpg",
    "backend"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@libsql/client": "^0.15.14",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "nodemon": "^3.1.9"
  }
}
